# IRCNL ATLAS — Variables de entorno
# Copiar este archivo como .env y completar con valores reales
# NUNCA subir el archivo .env a git

# ─── Base de datos PostgreSQL ──────────────────────────────────────────────────
DB_HOST=10.150.111.53
DB_PORT=5432
DB_NAME=db_ircnl_main
DB_USER=usr_ircnl_prod
DB_PASS=CAMBIAR_POR_PASSWORD_REAL

# ─── HubSpot API ───────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=CAMBIAR_POR_TOKEN_HUBSPOT
PIPELINE_ID=19584269

# ─── Autenticación JWT ─────────────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_POR_STRING_64_CHARS_ALEATORIO
JWT_EXPIRES_IN=8h

# ─── Token de administración (para endpoints internos) ─────────────────────────
ADMIN_TOKEN=CAMBIAR_POR_HASH_SHA256_ALEATORIO

# ─── Configuración del servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Sincronización ────────────────────────────────────────────────────────────
PAGE_SIZE=200
MAX_RETRIES=3
RETRY_DELAY=60000

# ─── Generación de valores seguros ─────────────────────────────────────────────
# JWT_SECRET:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ADMIN_TOKEN: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
