# ─── IRCNL ATLAS — Variables de entorno ───────────────────────────────────────
# Copiar como .env y completar con valores reales
# NUNCA subir el archivo .env a git
# Fase 2 | Sprint S1-5 | 07/03/2026

# ─── Base de datos PostgreSQL (.53) ───────────────────────────────────────────
DATABASE_URL=postgresql://usr_ircnl_prod:CAMBIAR_PASSWORD@10.150.111.53:5432/db_ircnl_main
DATABASE_URL_POA=postgresql://usr_ircnl_prod:CAMBIAR_PASSWORD@10.150.111.53:5432/db_poa_2026
DATABASE_URL_CATASTRO=postgresql://usr_ircnl_prod:CAMBIAR_PASSWORD@10.150.111.53:5432/db_catastro_tramites
DATABASE_URL_SEGURIDAD=postgresql://usr_ircnl_prod:CAMBIAR_PASSWORD@10.150.111.53:5432/db_seguridad_acceso
DATABASE_URL_SALUD=postgresql://usr_ircnl_prod:CAMBIAR_PASSWORD@10.150.111.53:5432/db_salud_integral

# ─── HubSpot API ───────────────────────────────────────────────────────────────
# Bearer token para POST /crm/v3/objects/tickets/search
HUBSPOT_API_KEY=CAMBIAR_POR_TOKEN_HUBSPOT

# ─── JWT RS256 ─────────────────────────────────────────────────────────────────
# Generar par de claves:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Formatear para .env (una sola línea con \n):
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' jwt_private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nCAMBIAR_CLAVE_PRIVADA_RSA_2048\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCAMBIAR_CLAVE_PUBLICA_RSA_2048\n-----END PUBLIC KEY-----"
JWT_ISSUER=tablero.ircnl.gob.mx
JWT_AUDIENCE=tablero-api
JWT_EXPIRY_MINUTES=480

# ─── pgcrypto — Cifrado LFPDPPP ───────────────────────────────────────────────
# Clave simétrica para cifrar: nombre_persona_tramite, correo_solicitante, curp, expediente_catastral
# Generar: openssl rand -hex 32
PGCRYPTO_KEY=CAMBIAR_POR_CLAVE_SIMETRICA_32BYTES

# ─── Redis (instalar en Sprint 2) ─────────────────────────────────────────────
REDIS_CONNECTION=10.150.111.52:6379
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_REDIS

# ─── Sincronización HubSpot ────────────────────────────────────────────────────
HUBSPOT_SYNC_INTERVAL_HOURS=1

# ─── ASP.NET Core ─────────────────────────────────────────────────────────────
# Producción (.52): ASPNETCORE_URLS=http://+:5000
# Desarrollo (.54): ASPNETCORE_URLS=http://+:5001
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# ─── Legacy worker.js (soporte durante migración de PM2 a .NET) ───────────────
DB_HOST=10.150.111.53
DB_PORT=5432
DB_NAME=db_ircnl_main
DB_USER=usr_ircnl_prod
DB_PASS=CAMBIAR_PASSWORD
PIPELINE_ID=19584269
PAGE_SIZE=200
MAX_RETRIES=3
RETRY_DELAY=60000

# ─── Generación segura de valores ─────────────────────────────────────────────
# PGCRYPTO_KEY:  openssl rand -hex 32
# JWT keys:      openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Redis pass:    openssl rand -base64 32
