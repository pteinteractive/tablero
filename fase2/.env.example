# ============================================================
# IRCNL Tablero Fase 2 — Variables de entorno
# Sprint 1 | v1.0 | 07/03/2026
# ============================================================
# NUNCA hardcodear valores reales en código fuente.
# Copiar como .env en cada nodo y completar con valores reales.
# Responsables de valores: ver CLAUDE.md sección 7.
# ============================================================

# --- HubSpot ---
HUBSPOT_API_KEY=             # Bearer token para POST /crm/v3/objects/tickets/search
HUBSPOT_SYNC_INTERVAL_HOURS=1

# --- Bases de datos PostgreSQL (.53) ---
DATABASE_URL=postgresql://usr_ircnl_prod:PASS@10.150.111.53:5432/db_ircnl_main
DATABASE_URL_POA=postgresql://usr_ircnl_prod:PASS@10.150.111.53:5432/db_poa_2026
DATABASE_URL_CATASTRO=postgresql://usr_ircnl_prod:PASS@10.150.111.53:5432/db_catastro_tramites
DATABASE_URL_SEGURIDAD=postgresql://usr_ircnl_prod:PASS@10.150.111.53:5432/db_seguridad_acceso
DATABASE_URL_SALUD=postgresql://usr_ircnl_prod:PASS@10.150.111.53:5432/db_salud_integral

# --- JWT RS256 (decisión cerrada — DT-01) ---
# Generar: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=             # RSA 2048 PEM — llave privada (firma tokens)
JWT_PUBLIC_KEY=              # RSA 2048 PEM — llave pública (verificación)
JWT_ISSUER=tablero.ircnl.gob.mx
JWT_AUDIENCE=tablero-api
JWT_EXPIRY_MINUTES=480

# --- Cifrado LFPDPPP (DT-09 — implementar S2) ---
# Campos cifrados: nombre_persona_tramite, correo_solicitante, curp, expediente_catastral
PGCRYPTO_KEY=                # Clave simétrica AES para pgcrypto.pgp_sym_encrypt

# --- Redis (.52) — instalar S2-4 ---
REDIS_CONNECTION=10.150.111.52:6379
REDIS_PASSWORD=              # requirepass (configurar en S2-4)

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production    # Development en nodo .54 (sandbox)
ASPNETCORE_URLS=http://+:5000        # 5001 en nodo .54

# --- Legacy worker.js (soporte durante migración Fase 1 → Fase 2) ---
DB_HOST=10.150.111.53
DB_PORT=5432
DB_NAME=db_ircnl_main
DB_USER=usr_ircnl_prod
DB_PASS=                     # Misma contraseña que DATABASE_URL
